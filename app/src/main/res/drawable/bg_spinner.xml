<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_spinner.xml — Fondo del Spinner de categorías
    Usado en: activity_producto_form.xml → spinnerCategoria

    Diseño: borde outline con esquinas redondeadas, consistente
    con el estilo OutlinedTextField del resto del formulario.
    Fondo blanco (colorBackground) con borde colorPrimary.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Estado: enfocado / presionado -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Fondo blanco -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/colorBackground" />
                    <corners android:radius="@dimen/textFieldCornerRadius" />
                </shape>
            </item>
            <!-- Borde primario más grueso al enfocar -->
            <item>
                <shape android:shape="rectangle">
                    <stroke
                        android:width="2dp"
                        android:color="@color/colorPrimary" />
                    <corners android:radius="@dimen/textFieldCornerRadius" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Estado: deshabilitado -->
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/colorSurface" />
                    <corners android:radius="@dimen/textFieldCornerRadius" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke
                        android:width="1dp"
                        android:color="@color/colorDivider" />
                    <corners android:radius="@dimen/textFieldCornerRadius" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Estado: normal (default) -->
    <item>
        <layer-list>
            <!-- Fondo blanco -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/colorBackground" />
                    <corners android:radius="@dimen/textFieldCornerRadius" />
                </shape>
            </item>
            <!-- Borde outline -->
            <item>
                <shape android:shape="rectangle">
                    <stroke
                        android:width="1dp"
                        android:color="@color/colorPrimary" />
                    <corners android:radius="@dimen/textFieldCornerRadius" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>